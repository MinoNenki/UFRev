# UFREV.com production base URL behind Cloudflare proxy/CDN
NEXT_PUBLIC_SITE_URL=https://ufrev.com

# === REQUIRED (CORE) ===
# Supabase authentication + database
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# OpenAI for AI analysis engine
OPENAI_API_KEY=your-openai-production-key

# Stripe payment processing (live mode)
STRIPE_SECRET_KEY=sk_live_replace_before_launch
STRIPE_WEBHOOK_SECRET=whsec_replace_with_live_webhook_secret
STRIPE_PRICE_STARTER=price_live_starter
STRIPE_PRICE_PRO=price_live_pro
STRIPE_PRICE_SCALE=price_live_scale
STRIPE_PRICE_PACK_9=price_live_pack9
STRIPE_PRICE_PACK_19=price_live_pack19
STRIPE_PRICE_PACK_39=price_live_pack39

# Security tokens (rotation + key separation)
# Generate with OpenSSL (if installed): openssl rand -base64 48
# PowerShell fallback (Windows):
#   $rng = New-Object System.Security.Cryptography.RNGCryptoServiceProvider
#   $b = New-Object byte[] 48; $rng.GetBytes($b); [Convert]::ToBase64String($b)
REWARD_TOKEN_SECRET_CURRENT=replace-with-a-long-random-production-secret
REWARD_TOKEN_SECRET_PREVIOUS=
REWARD_TOKEN_KID_CURRENT=rwd_v1
SIGNED_LINK_SECRET_CURRENT=replace-with-a-different-long-random-production-secret
SIGNED_LINK_SECRET_PREVIOUS=
SIGNED_LINK_KID_CURRENT=lnk_v1

# Legacy fallback (optional; can stay empty after migration)
REWARD_TOKEN_SECRET=

# Cron auth (header-based fallback)
MARKET_WATCH_CRON_SECRET=

# === INTEGRATIONS: E-COMMERCE STOREFRONTS ===
# Shopify — customer's storefront data sync
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# WooCommerce — open-source WP storefront
WOOCOMMERCE_STORE_URL=

# eBay — auction/fixed-price listings
EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=
EBAY_ENVIRONMENT=production
EBAY_SITE_ID=EBAY_US

# Allegro — Polish marketplace (MVP focus)
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_REDIRECT_URI=
ALLEGRO_ENVIRONMENT=production

# Amazon Seller Partner (optional future)
AMAZON_SELLER_PARTNER_APP_ID=
AMAZON_SELLER_PARTNER_CLIENT_ID=
AMAZON_SELLER_PARTNER_CLIENT_SECRET=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# === MONETIZATION: AD NETWORKS & PAYWALL ===
# Google AdSense display ads
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_ID=
GOOGLE_ADSENSE_PUBLISHER_ID=
GOOGLE_ADSENSE_MANAGEMENT_ACCESS_TOKEN=

# Google Ads (advertiser account integration) — optional
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# === AUTOMATION DEFAULTS ===
AUTOMATION_SYNC_INTERVAL_MINUTES=60
AUTOMATION_PRICE_FLOOR_PERCENT=18
AUTOMATION_PROFIT_GUARDRAIL_PERCENT=22

# === OPTIONAL: EMAIL / CRM NOTIFICATIONS ===
NOTIFICATION_EMAIL_FROM=ufrevsupport@gmail.com
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# === OPTIONAL: PRELAUNCH MODE ===
PRELAUNCH_MODE=false
PRELAUNCH_PASSWORD=
PRELAUNCH_COOKIE_NAME=ufrev_preview_access
