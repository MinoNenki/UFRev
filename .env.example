# UFREV.com production base URL behind Cloudflare proxy/CDN
NEXT_PUBLIC_SITE_URL=https://ufrev.com

# Core production services
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
OPENAI_API_KEY=your-openai-production-key

# Stripe live mode for UFREV.com
STRIPE_SECRET_KEY=sk_live_replace_before_launch
STRIPE_WEBHOOK_SECRET=whsec_replace_with_live_webhook_secret
STRIPE_PRICE_STARTER=price_live_starter
STRIPE_PRICE_STARTER_19=price_live_starter_legacy
STRIPE_PRICE_PRO=price_live_pro
STRIPE_PRICE_GROWTH_49=price_live_pro_legacy
STRIPE_PRICE_SCALE=price_live_scale
STRIPE_PRICE_SCALE_99=price_live_scale_legacy
STRIPE_PRICE_COMMAND_149=price_live_scale_command_legacy
STRIPE_PRICE_PACK_9=price_live_pack9
STRIPE_PRICE_PACK_19=price_live_pack19
STRIPE_PRICE_PACK_39=price_live_pack39

# Email / notifications
NOTIFICATION_EMAIL_FROM=ufrevsupport@gmail.com

# Google ad providers
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
